  {
    "id": 9,
    "name": "Yaavadunam Tavadunam",
    "sanskrit": "यावदूनं तावदूनं",
    "meaning": "Whatever the deficiency, lessen it further",
    "color": "#E1F5EE",
    "textColor": "#085041",
    "dot": "#1D9E75",
    "desc": "Find the cube of numbers near a base (10, 100) using a 3-part formula based on the deviation.",
    "steps": [
      "Find deviation d = number minus base (e.g. 12 - 10 = 2).",
      "Left part: number + 2d",
      "Middle part: 3 times d squared",
      "Right part: d cubed",
      "Combine carefully with carries."
    ],
    "examples": [
      {
        "q": "12 cubed",
        "steps": [
          "d = 12-10 = 2",
          "Left: 12+2x2 = 16",
          "Mid: 3x4 = 12",
          "Right: 8",
          "16|12|8 with carry = 1728"
        ]
      },
      {
        "q": "11 cubed",
        "steps": [
          "d = 1",
          "Left: 11+2 = 13",
          "Mid: 3x1 = 3",
          "Right: 1",
          "Answer: 1331"
        ]
      }
